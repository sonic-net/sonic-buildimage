    "PSU1":
    {
        "dev_info": {"device_type":"PSU"},
        "dev_attr": {"dev_idx":"0", "num_psu_fans": "1"},
        "bmc": {
            "ipmitool": {
                "attr_list":
                [
                    {"attr_name":"psu_present", "bmc_cmd":"r=$(ipmitool raw 0x3a 0x29 | tr -d ' ') && printf '%d' $(((0x$r >> 0) & 0x1))", "raw": "1", "type":"raw"},
                    {"attr_name":"psu_power_good", "bmc_cmd":"r=$(ipmitool raw 0x3a 0x29 | tr -d ' ') && printf '%d' $(((0x$r >> 6) & 0x1))", "raw":"1", "type":"raw"},
                    {"attr_name":"psu_model_name", "bmc_cmd":"ipmitool fru print 7", "raw": "0", "field_name":"Product Name", "separator":": ","field_pos":"2"},
                    {"attr_name":"psu_serial_num", "bmc_cmd":"ipmitool fru print 7", "raw": "0", "field_name":"Product Serial", "separator":": ","field_pos":"2"},
                    {"attr_name":"psu_mfr_id", "bmc_cmd":"ipmitool fru print 7", "raw": "0", "field_name":"Product Manufacturer", "separator":": ", "field_pos":"2"},
                    {"attr_name":"psu_p_out", "bmc_cmd":"printf '%x' $(( 0x$(ipmitool raw 0x04 0x2d 0x14 | xargs | cut -d' ' -f1) * 6700000 ))", "raw":"1", "type": "raw"},
                    {"attr_name":"psu_v_out", "bmc_cmd":"printf '%x' $(( 0x$(ipmitool raw 0x04 0x2d 0x2b | xargs | cut -d' ' -f1) * 392 ))", "raw":"1", "type": "raw"},
                    {"attr_name":"psu_i_out", "bmc_cmd":"printf '%x' $(( 0x$(ipmitool raw 0x04 0x2d 0x02 | xargs | cut -d' ' -f1) * 118 ))", "raw":"1", "type": "raw"},
                    {"attr_name":"psu_p_in", "bmc_cmd":"printf '%x' $(( 0x$(ipmitool raw 0x04 0x2d 0x13 | xargs | cut -d' ' -f1) * 7500000 ))", "raw":"1", "type": "raw"},
                    {"attr_name":"psu_v_in", "bmc_cmd":"printf '%x' $(( 0x$(ipmitool raw 0x04 0x2d 0x2a | xargs | cut -d' ' -f1) * 1040 ))", "raw":"1", "type": "raw"},
                    {"attr_name":"psu_i_in", "bmc_cmd":"printf '%x' $(( 0x$(ipmitool raw 0x04 0x2d 0x01 | xargs | cut -d' ' -f1) * 43 ))", "raw":"1", "type": "raw"},
                    {"attr_name":"psu_fan1_speed_rpm", "bmc_cmd":"r=$(ipmitool raw 0x3a 0x26 0x02 0x04) && echo \"$r\" | awk '{print \"0x\"$2$1}' ", "raw":"1", "type": "raw"},
                    {"attr_name":"psu_temp1_input", "bmc_cmd":"printf '%x' $(( 0x$(ipmitool raw 0x04 0x2d 0x1f | xargs | cut -d' ' -f1) * 1000 ))", "raw":"1", "type": "raw"}
                ]
            }
        }
    },

