{%- set default_cable = '40m' %}

{%- macro generate_buffer_pool_and_profiles() %}
    "BUFFER_POOL": {
        "ingress_lossless_pool": {
            "xoff": "24576",
            "size": "1595776",
            "type": "ingress",
            "mode": "dynamic"
        },
        "egress_lossless_pool": {
            "size": "4125504",
            "type": "egress",
            "mode": "static"
        },
        "egress_lossy_pool": {
            "size": "1595776",
            "type": "egress",
            "mode": "dynamic"
        }
    },
    "BUFFER_PROFILE": {
        "ingress_lossy_profile": {
            "pool":"ingress_lossless_pool",
            "size":"0",
            "dynamic_th":"3"
        },
        "egress_lossless_profile": {
            "pool":"egress_lossless_pool",
            "size":"0",
            "dynamic_th":"3"
        },
        "egress_lossy_profile": {
            "pool":"egress_lossless_pool",
            "size":"1518",
            "dynamic_th":"3"
        }
    },
{%- endmacro %}
{%- macro generate_pg_profils(PORT_ACTIVE) %}
    "BUFFER_PG": {
{% for port in (PORT_ACTIVE.split(',') if PORT_ACTIVE is string else PORT_ACTIVE) if port %}
        "{{ port }}|0": {
            "profile" : "ingress_lossy_profile"
        }{% if not loop.last %},{% endif %}
{% endfor %}
    },
{%- endmacro %}

{% macro generate_queue_buffers(PORT_ACTIVE) %}
    "BUFFER_QUEUE": {
{% for port in (PORT_ACTIVE.split(',') if PORT_ACTIVE is string else PORT_ACTIVE) if port %}
        "{{ port }}|0-6": {
            "profile" : "egress_lossy_profile"
        }{% if not loop.last %},{% endif %}
{% endfor %}
    }
{% endmacro %}
