{
    "XCVR":
    {
        "xcvr_present":
        {
            "i2c":
            {
                "valmap-SFP28": {"0": true, "1": false},
                "valmap-QSFP28": {"0":true, "1":false},
                "valmap-QSFP-DD": {"0":true, "1":false}
            }
        },

        "plug_status":
        {
            "inserted": "1",
            "removed": "0"
        }
    },
    "PSU":
    {
        "psu_present":
        {
            "i2c":
            {
                "valmap": {"1": true, "0": false}
            }
        },

        "psu_power_good":
        {
            "i2c":
            {
                "valmap": {"1": true, "0": false}
            }
        },

        "psu_fan_dir":
        {
            "i2c":
            {
                "valmap": {"0": "exhaust", "1": "intake" }
            }
        },
        "PSU_FAN_MAX_SPEED": "18000"
    },
    "FAN": 
    {
        "direction":
        {
            "i2c":
            {
                "valmap": {"1": "intake", "0": "exhaust"}
            }
        },
        "present":
        {
            "i2c":
            {
                "valmap": {"1": true, "0": false}
            }
        },
        "duty_cycle_to_pwm": "lambda dc: dc*255/100",
        "pwm_to_duty_cycle": "lambda pwm: pwm*100/255",
        "FAN_MAX_SPEED":"20300"
    },
    "REBOOT_CAUSE":
    {
        "reboot_cause_file": "/host/reboot-cause/reboot-cause.txt"
    }
}
