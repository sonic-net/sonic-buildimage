{% macro install_debian_packages(packages) -%}
RUN dpkg -i \
{%- for deb in packages %}
    /debs/{{ deb }} {%- if not loop.last %} \ {%- endif %}
{%- endfor %} || apt-get -y install -f --no-remove
{%- endmacro %}

{% macro install_python2_wheels(packages) -%}
RUN cd /python-wheels/ && pip2 install {{ packages | join(' ') }}
{%- endmacro %}

{% macro install_python3_wheels(packages) -%}
RUN cd /python-wheels/ && pip3 install {{ packages | join(' ') }}
{%- endmacro %}

{% macro install_python_wheels(packages) -%}
{%- set py2_pkgs, py3_pkgs = [], [] %}
{%- for pkg in packages %}
    {%- if 'py3' in pkg %}
       {{- py3_pkgs.append(pkg) or '' }}
    {%- else %}
       {{- py2_pkgs.append(pkg) or '' }}
    {%- endif %}
{%- endfor %}
{%- if py3_pkgs | length %}
{{ install_python3_wheels(py3_pkgs) }}
{%- endif %}
{%- if py2_pkgs | length %}
{{  install_python2_wheels(py2_pkgs) }}
{%- endif %}
{%- endmacro %}

{% macro copy_files(prefix, files, dest) -%}
COPY \
    {%- for file in files %}
        {{ prefix }}/{{ file }} \
    {%- endfor %}
    {{ dest }}
{%- endmacro %}

{% macro install_offending_packages(packages) -%}
    {%- for pkg in packages %}
        RUN pip3 install {{ pkg }}
        RUN pip3 install setuptools
    {%- endfor %}
{%- endmacro %}

{% macro rsync_from_builder_stage() -%}
RUN --mount=type=bind,from=base,target=/changes-to-image rsync -axAX --omit-dir-times --no-D --exclude=/sys --exclude=/proc --exclude=/dev --exclude=resolv.conf /changes-to-image/ /
{%- endmacro %}

{% macro apply_relp_udp_failover() -%}
# Modify the inherited /etc/rsyslog.conf so the omrelp forwarding action
# suspends on first failure and falls back to omfwd UDP/514. Keeps the
# image compatible with hosts that only listen on UDP/514, while still
# using RELP/2514 on newer hosts.
#
# Notes (rsyslog 8.2504.0):
#   * action.resumeRetryCount="0" so the action suspends on the first
#     failure. "-1" retries forever and prevents fallback; ">0" only
#     delays it.
#   * The omrelp action must not have its own queue. A per-action queue
#     defers the send to a worker thread, so the suspended flag is set
#     asynchronously and execOnlyWhenPreviousIsSuspended on the UDP
#     action sees stale state.
RUN sed -i -E 's|^\*\.\* action\(type="omrelp".*$|*.* action(type="omrelp" target=`echo $SYSLOG_TARGET_IP` port="2514" action.resumeRetryCount="0" action.resumeInterval="30" Template="ForwardFormatInContainer")\n*.* action(type="omfwd" target=`echo $SYSLOG_TARGET_IP` port="514" protocol="udp" action.execOnlyWhenPreviousIsSuspended="on" Template="ForwardFormatInContainer")|' /etc/rsyslog.conf
{%- endmacro %}
