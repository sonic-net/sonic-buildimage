!
! template: bgpd/templates/msft.general/v4.mgmtspine.ma/peer-group.conf.j2
!
  neighbor MA_V4 peer-group
  address-family ipv4 unicast
    neighbor MA_V4 activate
    neighbor MA_V4 soft-reconfiguration inbound
    neighbor MA_V4 route-map FROM_MA_V4 in
    neighbor MA_V4 route-map TO_MA_V4 out
    neighbor MA_V4 send-community
    neighbor MA_V4 maximum-prefix 4000 90 warning-only
  exit-address-family
!
! end of template: bgpd/templates/msft.general/v4.mgmtspine.ma/peer-group.conf.j2
!
