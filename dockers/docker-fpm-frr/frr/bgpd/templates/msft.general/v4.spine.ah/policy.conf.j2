!
! template: bgpd/templates/msft.general/v4.spine.ah/policy.conf.j2
!
bgp community-list standard INREGION_LEAK_COMMUNITY permit 8075:8848
bgp community-list standard FABRIC_INFRA_COMMUNITY permit 8075:316
bgp community-list standard NO_EXPORT permit no-export
bgp community-list standard DEVICE_INTERNAL_FALLBACK_COMMUNITY permit {{ constants.bgp.internal_fallback_community }}
bgp community-list standard ANCHOR_ROUTE_COMMUNITY permit {{ constants.bgp.anchor_route_community }}
bgp community-list standard LOCAL_ANCHOR_ROUTE_COMMUNITY permit {{ constants.bgp.local_anchor_route_community }}
bgp community-list standard ANCHOR_CONTRIBUTING_ROUTE_COMMUNITY permit {{ constants.bgp.anchor_contributing_route_community }}
!
bgp as-path access-list WAN_ASNS permit _8075_
bgp as-path access-list WAN_ASNS permit _8074_
bgp as-path access-list WAN_ASNS permit _8072_
bgp as-path access-list RNG_ASNS permit _64915_
bgp as-path access-list RNG_ASNS permit _64945_
bgp as-path access-list T2_LOOPBACK permit ^$
!
ip prefix-list DEFAULT_IPV4 permit 0.0.0.0/0
!
route-map SELECTIVE_ROUTE_DOWNLOAD_V4 deny 10
  match community LOCAL_ANCHOR_ROUTE_COMMUNITY
!
route-map SELECTIVE_ROUTE_DOWNLOAD_V4 permit 1000
!
route-map TAG_ANCHOR_COMMUNITY permit 10
  set community {{ constants.bgp.local_anchor_route_community }} {{ constants.bgp.anchor_route_community }} additive
!
route-map FROM_AZNG_MIGRATION_FILTER_V4 permit 1
  match community FABRIC_INFRA_COMMUNITY
!
route-map FROM_AZNG_MIGRATION_FILTER_V4 deny 2
!
{% if slice_type is not defined or slice_type != 'AZNG_Production' %}
route-map FROM_AH_V4 permit 10
  call FROM_AZNG_MIGRATION_FILTER_V4
{% endif %}
route-map FROM_AH_V4 deny 100
  match ip address prefix-list DEFAULT_IPV4
!
route-map FROM_AH_V4 deny 200
  match as-path WAN_ASNS
!
route-map FROM_AH_V4 deny 300
  match as-path RNG_ASNS
!
route-map FROM_AH_V4 permit 400
  match community FABRIC_INFRA_COMMUNITY
{% if CONFIG_DB__DEVICE_METADATA['localhost']['switch_type'] == 'voq' %}
  set tag {{ constants.bgp.route_do_not_send_appdb_tag }}
{% else %}
  set tag {{ constants.bgp.route_eligible_for_fallback_to_default_tag }}
{% endif %}
  set community {{ constants.bgp.internal_fallback_community }} additive
!
route-map FROM_AH_V4 permit 500
  match community NO_EXPORT
  set local-preference 80
{% if CONFIG_DB__DEVICE_METADATA['localhost']['switch_type'] == 'voq' %}
  set tag {{ constants.bgp.route_do_not_send_appdb_tag }}
{% else %}
  set tag {{ constants.bgp.route_eligible_for_fallback_to_default_tag }}
{% endif %}
  set community {{ constants.bgp.internal_fallback_community }} additive
!
route-map FROM_AH_V4 permit 1000
  set local-preference 80
  set community no-export additive
{% if CONFIG_DB__DEVICE_METADATA['localhost']['switch_type'] == 'voq' %}
  set tag {{ constants.bgp.route_do_not_send_appdb_tag }}
{% else %}
  set tag {{ constants.bgp.route_eligible_for_fallback_to_default_tag }}
{% endif %}
  on-match next
!
route-map FROM_AH_V4 permit 1100
  set community {{ constants.bgp.internal_fallback_community }} additive
!
route-map TO_AZNG_MIGRATION_FILTER_V4 permit 1
  match ip address prefix-list DEFAULT_IPV4
!
route-map TO_AZNG_MIGRATION_FILTER_V4 permit 2
  match as-path T2_LOOPBACK
  set community 8075:316 additive
!
route-map TO_AZNG_MIGRATION_FILTER_V4 permit 3
  match community FABRIC_INFRA_COMMUNITY
!
route-map TO_AZNG_MIGRATION_FILTER_V4 deny 4
!
{% if slice_type is not defined or slice_type != 'AZNG_Production' %}
route-map TO_AH_V4 permit 10
  call TO_AZNG_MIGRATION_FILTER_V4
{% endif %}
!
route-map TO_AH_V4 deny 1
  match community LOCAL_ANCHOR_ROUTE_COMMUNITY
!
route-map TO_AH_V4 permit 100
  match ip address prefix-list DEFAULT_IPV4
!
route-map TO_AH_V4 deny 200
  match as-path WAN_ASNS
!
route-map TO_AH_V4 deny 300
  match as-path RNG_ASNS
!
route-map TO_AH_V4 deny 400
  match community INREGION_LEAK_COMMUNITY
!
route-map TO_AH_V4 permit 1000
!
! end of template: bgpd/templates/msft.general/v4.spine.ah/policy.conf.j2
!
