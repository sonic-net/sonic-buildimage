!
! template: bgpd/templates/msft.general/v4.smartswitch.azd/instance.conf.j2
!
  neighbor {{ neighbor_addr }} remote-as {{ bgp_session['asn'] }}
  neighbor {{ neighbor_addr }} description {{ bgp_session['name'] }}
  neighbor {{ neighbor_addr }} peer-group TIER1_V4
{% if need_to_set_timers %}
  neighbor {{ neighbor_addr }} timers {{ bgp_session['keepalive'] }} {{ bgp_session['holdtime'] }}
{% endif %}
{% if bgp_session['admin_status'] | lower == 'down' %}
  neighbor {{ neighbor_addr }} shutdown
{% endif %}
!
  address-family ipv4 unicast
    neighbor {{ neighbor_addr }} activate
  exit-address-family
!
! end of template: bgpd/templates/msft.general/v4.smartswitch.azd/instance.conf.j2
!
