!
! template: bgpd/templates/msft.general/v4.smartswitch.azd/policy.conf.j2
!
{% import 'common/functions.conf.j2' as common %}
{% set lo0_ipv4 = common.get_ipv4_loopback_address(CONFIG_DB__LOOPBACK_INTERFACE, "Loopback0") | ip %}
{% set lo6_ipv4 = common.get_ipv4_loopback_address(CONFIG_DB__LOOPBACK_INTERFACE, "Loopback6") | ip %}
!
ip prefix-list PL_LoopbackV4 seq 5 permit {{ lo0_ipv4 }}/32
ip prefix-list DEFAULT_IPV4 seq 5 permit 0.0.0.0/0
ip prefix-list IPV4_32_ONLY seq 5 permit 0.0.0.0/0 ge 32
ip prefix-list STD_TYCOON_LOOPBACK seq 10 permit {{ lo0_ipv4 }}/32
!
{% if lo6_ipv4 is not none %}
ip prefix-list REG_TYCOON_LOOPBACK seq 10 permit {{ lo6_ipv4 }}/32
{% endif %}
!
route-map ADVERTISE_AZURE_TYCOON_LOOPBACKS permit 10
  match ip address prefix-list STD_TYCOON_LOOPBACK
  set community 8075:10451
!
route-map ADVERTISE_AZURE_TYCOON_LOOPBACKS permit 30
  match ip address prefix-list REG_TYCOON_LOOPBACK
  set community 8075:420 8075:10451
!
route-map ADVERTISE_AZURE_TYCOON_LOOPBACKS deny 40
!
route-map FROM_TIER1_V4 permit 10
 match ip address prefix-list DEFAULT_IPV4
exit
!
route-map FROM_TIER1_V4 permit 20
 match ip address prefix-list IPV4_32_ONLY
exit
!
route-map FROM_TIER1_V4 deny 100
!
bgp community alias 8075:420 COMM_REG_TYCOON_LOOPBACK
bgp community alias 8075:10451 COMM_STD_TYCOON_LOOPBACK
!
route-map TO_WLPARTNER_V4 permit 10
  match ip address prefix-list DEFAULT_IPV4
!
route-map TO_WLPARTNER_V4 deny 100
!
ip nht resolve-via-default
!
! end of template: bgpd/templates/msft.general/v4.smartswitch.azd/policy.conf.j2
!
