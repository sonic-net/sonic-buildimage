!
! template: bgpd/templates/msft.general/v4.smartswitch.azd/peer-group.conf.j2
!
{% import 'common/functions.conf.j2' as common %}
{% set lo0_ipv4 = common.get_ipv4_loopback_address(CONFIG_DB__LOOPBACK_INTERFACE, "Loopback0") | ip %}
{% set lo6_ipv4 = common.get_ipv4_loopback_address(CONFIG_DB__LOOPBACK_INTERFACE, "Loopback6") | ip %}
  neighbor TIER1_V4 peer-group
  address-family ipv4 unicast
    network {{ lo0_ipv4 }}/32
{% if lo6_ipv4 is not none %}
    network {{ lo6_ipv4 }}/32
{% endif %}
    neighbor TIER1_V4 activate
    neighbor TIER1_V4 soft-reconfiguration inbound
    neighbor TIER1_V4 allowas-in 1
    neighbor TIER1_V4 route-map FROM_TIER1_V4 in
    neighbor TIER1_V4 route-map ADVERTISE_AZURE_TYCOON_LOOPBACKS out
    maximum-paths 64
  exit-address-family
!
! end of template: bgpd/templates/msft.general/v4.smartswitch.azd/peer-group.conf.j2
!
