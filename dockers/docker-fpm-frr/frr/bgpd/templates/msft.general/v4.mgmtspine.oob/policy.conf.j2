!
! template: bgpd/templates/msft.general/v4.mgmtspine.oob/policy.conf.j2
!
ip prefix-list DEFAULT_IPV4 seq 5 permit 0.0.0.0/0
!
ip prefix-list AGGREGATE_ROUTES_V4 seq 5 permit 127.0.0.1/32
!
ip prefix-list AGGREGATE_CONTRIBUTING_ROUTES_V4 seq 5 permit 127.0.0.1/32
!
{% if device_location_type is defined and device_location_type in ['Edge'] %}
ip community-list standard GATEWAY_ROUTE_COMMUNITY permit 8075:8803
!
ip community-list standard OOB_DEFAULT_COMMUNITY permit 8075:8804
!
{% endif %}
route-map TO_MB_PATH_V4 deny 100
  match ip address prefix-list DEFAULT_IPV4
!
{% if device_location_type is defined and device_location_type in ['Edge'] %}
route-map TO_MB_PATH_V4 deny 105
  match community GATEWAY_ROUTE_COMMUNITY
!
{% endif %}
route-map TO_MB_PATH_V4 permit 110
  match ip address prefix-list AGGREGATE_ROUTES_V4
  set community 8075:9120 additive
!
route-map TO_MB_PATH_V4 permit 120
  match ip address prefix-list AGGREGATE_CONTRIBUTING_ROUTES_V4
  set community 8075:9120 no-advertise additive
!
route-map TO_MB_PATH_V4 permit 1000
 set community 8075:9120 additive
!
route-map FROM_MB_PATH_V4 permit 100
  match ip address prefix-list DEFAULT_IPV4
  set as-path prepend 64512
{% if device_location_type is defined and device_location_type in ['Edge'] %}
  set community 8075:8804 additive
{% endif %}
!
route-map FROM_MB_PATH_V4 deny 1000
!
! end of template: bgpd/templates/msft.general/v4.mgmtspine.oob/policy.conf.j2
!
