!
! template: bgpd/templates/msft.general/v4.mgmtspine.oob/peer-group.conf.j2
!
  neighbor MB_PATH_V4 peer-group
  address-family ipv4 unicast
    neighbor MB_PATH_V4 activate
    neighbor MB_PATH_V4 soft-reconfiguration inbound
    neighbor MB_PATH_V4 route-map FROM_MB_PATH_V4 in
    neighbor MB_PATH_V4 route-map TO_MB_PATH_V4 out
    neighbor MB_PATH_V4 send-community
    neighbor MB_PATH_V4 maximum-prefix 4000 90 warning-only
  exit-address-family
!
! end of template: bgpd/templates/msft.general/v4.mgmtspine.oob/peer-group.conf.j2
!
