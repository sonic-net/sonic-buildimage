!
! template: bgpd/templates/msft.general/v6.mgmtleaf.mgmttor.all/policy.conf.j2
!
ipv6 prefix-list DEFAULT_IPV6 seq 5 permit ::/0
!
bgp as-path access-list LOCALROUTES permit ^$
!
route-map TO_{{ peer_group_type }} permit 1000
!
route-map FROM_{{ peer_group_type }} permit 100
  set ipv6 next-hop prefer-global
  on-match next
!
route-map FROM_{{ peer_group_type }} permit 1000
!
! end of template: bgpd/templates/msft.general/v6.mgmtleaf.mgmttor.all/policy.conf.j2
!
