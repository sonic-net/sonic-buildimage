!
! template: bgpd/templates/msft.general/v4.mgmtagg.oob/policy.conf.j2
!
ip prefix-list DEFAULT_IPV4 seq 5 permit 0.0.0.0/0
!
route-map TO_MB_PATH_V4 deny 10
  match ip address prefix-list DEFAULT_IPV4
!
route-map TO_MB_PATH_V4 permit 1000
!
route-map FROM_MB_PATH_V4 permit 10
  match ip address prefix-list DEFAULT_IPV4
  set as-path prepend 64582
!
route-map FROM_MB_PATH_V4 deny 1000
!
! end of template: bgpd/templates/msft.general/v4.mgmtagg.oob/policy.conf.j2
!
