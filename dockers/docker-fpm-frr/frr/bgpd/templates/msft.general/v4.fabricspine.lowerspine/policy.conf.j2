!
! template: bgpd/templates/msft.general/v4.fabricspine.lowerspine/policy.conf.j2
!
{% from "common/functions.conf.j2" import get_ipv4_loopback_address %}
{% set lo_ipv4 = get_ipv4_loopback_address(CONFIG_DB__LOOPBACK_INTERFACE, "Loopback0") | ip %}
!
ip prefix-list DEFAULT_IPV4 permit 0.0.0.0/0
!
route-map FROM_LOWERSPINE_V4 permit 100
{% if lo_ipv4 is not none%}
  set originator-id {{ lo_ipv4 }}
{% endif %}
!
route-map TO_LOWERSPINE_V4 deny 100
  match ip address prefix-list DEFAULT_IPV4
!
route-map TO_LOWERSPINE_V4 permit 200
  match ip address prefix-list PL_LoopbackV4
!
route-map TO_LOWERSPINE_V4 permit 300
  set community {{ constants.bgp.fabric_t2_community  }} additive