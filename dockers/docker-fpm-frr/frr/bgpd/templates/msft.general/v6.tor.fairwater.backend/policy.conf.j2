!
! template: bgpd/templates/msft.general/v6.tor.fairwater.backend/policy.conf.j2
!
bgp community-list standard LargeComputeAI_BE_Loopback permit 65219:999
bgp community-list standard LargeComputeAI_BE_Vlan permit 65219:998
! community 65219:65219 is used for prefixes coming from other fairwater stamps
bgp community-list standard COMM_FAIRWATER_BE_PREFIX permit 65219:65219
!
route-map TO_BE_TIER1_V6 deny 100
  match community LargeComputeAI_BE_Loopback
!
route-map TO_BE_TIER1_V6 deny 110
  match community LargeComputeAI_BE_Vlan
!
route-map TO_BE_TIER1_V6 deny 120
  match community COMM_FAIRWATER_BE_PREFIX
!
route-map TO_BE_TIER1_V6 permit 200
!
!
route-map FROM_BE_TIER1_V6 permit 100
  on-match next
  set ipv6 next-hop prefer-global
!
route-map FROM_BE_TIER1_V6 permit 200
!
! end of template: bgpd/templates/msft.general/v6.tor.fairwater.backend/policy.conf.j2
!
