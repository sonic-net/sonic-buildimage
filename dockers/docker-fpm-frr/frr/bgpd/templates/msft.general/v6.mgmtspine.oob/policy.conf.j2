!
! template: bgpd/templates/msft.general/v6.mgmtspine.oob/policy.conf.j2
!
ipv6 prefix-list DEFAULT_IPV6 seq 5 permit ::/0
!
ipv6 prefix-list AGGREGATE_ROUTES_V6 seq 5 permit ::1/128
!
ipv6 prefix-list AGGREGATE_CONTRIBUTING_ROUTES_V6 seq 5 permit ::1/128
!
route-map TO_VPN_OOB_V6 deny 100
 match ipv6 address prefix-list DEFAULT_IPV6
!
route-map TO_VPN_OOB_V6 permit 110
  match ipv6 address prefix-list AGGREGATE_ROUTES_V6
  set community 8075:9120 additive
!
route-map TO_VPN_OOB_V6 permit 120
  match ipv6 address prefix-list AGGREGATE_CONTRIBUTING_ROUTES_V6
  set community 8075:9120 no-advertise additive
!
route-map TO_VPN_OOB_V6 permit 1000
 set community 8075:9120 additive
!
route-map FROM_VPN_OOB_V6 permit 100
  set ipv6 next-hop prefer-global
  on-match next
!
route-map FROM_VPN_OOB_V6 permit 110
  match ipv6 address prefix-list DEFAULT_IPV6
  set as-path prepend 64512
!
route-map FROM_VPN_OOB_V6 deny 1000
!
! end of template: bgpd/templates/msft.general/v6.mgmtspine.oob/policy.conf.j2
!
