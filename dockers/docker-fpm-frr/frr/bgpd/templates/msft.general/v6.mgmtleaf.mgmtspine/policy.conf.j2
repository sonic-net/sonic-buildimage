!
! template: bgpd/templates/msft.general/v6.mgmtleaf.mgmtspine/policy.conf.j2
!
ipv6 prefix-list DEFAULT_IPV6 seq 5 permit ::/0
!
bgp as-path access-list LOCALROUTES permit ^$
!
bgp community-list standard FABRIC_INFRA_COMMUNITY permit 8075:316
!
route-map TO_TIER2_V6 permit 100
  match ipv6 address prefix-list DEFAULT_IPV6
  set community no-export additive
!
{% if neighbor_type == 'MgmtSpineRouter' %}
route-map TO_TIER2_V6 permit 200
  match as-path LOCALROUTES
  set community 8075:316 additive
!
route-map TO_TIER2_V6 permit 1000
  set community 8075:316 additive
{% else %}
route-map TO_TIER2_V6 permit 1000
{% endif %}
!
route-map FROM_TIER2_V6 permit 100
  set ipv6 next-hop prefer-global
  on-match next
!
route-map FROM_TIER2_V6 permit 1000
!
! end of template: bgpd/templates/msft.general/v6.mgmtleaf.mgmtspine/policy.conf.j2
!
