!
! template: bgpd/templates/msft.monitors/peer-group.conf.j2
!
  neighbor BGPMON peer-group
! FIXME: check that with frr. that was part of quagga
  neighbor BGPMON activate
!
  neighbor BGPMON_V6 peer-group
  neighbor BGPMON_V6 passive
{% if CONFIG_DB__DEVICE_METADATA['localhost']['type'] == 'SpineRouter' %}
  neighbor BGPMON_V6 update-source Loopback4096
{% elif loopback0_ipv4 %}
  neighbor BGPMON update-source {{ loopback0_ipv4 | ip }}
{% endif %}
  neighbor BGPMON route-map FROM_BGPMON in
  neighbor BGPMON route-map TO_BGPMON out
  neighbor BGPMON send-community
  neighbor BGPMON maximum-prefix 1
  address-family ipv4
    neighbor BGPMON_V6 activate
    neighbor BGPMON_V6 addpath-tx-all-paths
    neighbor BGPMON_V6 soft-reconfiguration inbound
    neighbor BGPMON_V6 route-map FROM_BGPMON_V6 in
    neighbor BGPMON_V6 route-map TO_BGPMON_V6 out
    neighbor BGPMON_V6 send-community
    neighbor BGPMON_V6 maximum-prefix 200
  exit-address-family
  address-family ipv6
    neighbor BGPMON_V6 activate
    neighbor BGPMON_V6 addpath-tx-all-paths
    neighbor BGPMON_V6 soft-reconfiguration inbound
    neighbor BGPMON_V6 route-map FROM_BGPMON_V6 in
    neighbor BGPMON_V6 route-map TO_BGPMON_V6 out
    neighbor BGPMON_V6 send-community
    neighbor BGPMON_V6 maximum-prefix 200
  exit-address-family
!
! end of template: bgpd/templates/msft.monitors/peer-group.conf.j2
!
