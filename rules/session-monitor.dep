SPATH       := $($(SESSION_MONITOR_PY3)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/session-monitor.mk rules/session-monitor.dep   
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
SMDEP_FILES := $(addprefix $(SPATH)/,$(shell cd $(SPATH) && git ls-files))

$(SESSION_MONITOR_PY3)_CACHE_MODE  := GIT_CONTENT_SHA 
$(SESSION_MONITOR_PY3)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(SESSION_MONITOR_PY3)_DEP_FILES   := $(DEP_FILES)
$(SESSION_MONITOR_PY3)_SMDEP_FILES := $(SMDEP_FILES)
$(SESSION_MONITOR_PY3)_SMDEP_PATHS := $(SPATH)