
SPATH       := $($(SONIC_ACMS_PY3)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/sonic-acms-py3.mk rules/sonic-acms-py3.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(SPATH))

$(SONIC_ACMS_PY3)_CACHE_MODE  := GIT_CONTENT_SHA
$(SONIC_ACMS_PY3)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(SONIC_ACMS_PY3)_DEP_FILES   := $(DEP_FILES)

