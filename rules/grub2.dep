DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/grub2.mk rules/grub2.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
# resolute: grub2 is an ONLINE_DEB (fetched from the Ubuntu pool) with no
# in-repo source to hash, so no SPATH / git ls-files (matches rules/linux-kernel.dep).

$(GRUB2_COMMON)_CACHE_MODE  := GIT_CONTENT_SHA
$(GRUB2_COMMON)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(GRUB2_COMMON)_DEP_FILES   := $(DEP_FILES)
