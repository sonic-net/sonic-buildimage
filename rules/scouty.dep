SPATH       := $($(SONIC_SCOUTY)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/scouty.mk rules/scouty.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(SPATH))

$(SONIC_SCOUTY)_CACHE_MODE    := GIT_CONTENT_SHA
$(SONIC_SCOUTY)_DEP_FLAGS     := $(SONIC_COMMON_FLAGS_LIST)
$(SONIC_SCOUTY)_DEP_FILES     := $(DEP_FILES)
$(SONIC_SCOUTY)_CACHE_OVERRIDE := $(SONIC_DPKG_CACHE_METHOD_OVERRIDE)
