
DPATH       := $($(DOCKER_SMARTSWITCH_AZS)_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/docker-smartswitch-azs.mk rules/docker-smartswitch-azs.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(DPATH))

$(DOCKER_SMARTSWITCH_AZS)_CACHE_MODE  := GIT_CONTENT_SHA 
$(DOCKER_SMARTSWITCH_AZS)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(DOCKER_SMARTSWITCH_AZS)_DEP_FILES   := $(DEP_FILES)

$(eval $(call add_dbg_docker,$(DOCKER_SMARTSWITCH_AZS),$(DOCKER_SMARTSWITCH_AZS)))

