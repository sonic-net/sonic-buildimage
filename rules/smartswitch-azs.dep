SPATH       := $($(SMARTSWITCH_AZS_PY3)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/smartswitch-azs.mk rules/smartswitch-azs.dep   
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
SMDEP_FILES := $(addprefix $(SPATH)/,$(shell cd $(SPATH) && git ls-files))

$(SMARTSWITCH_AZS_PY3)_CACHE_MODE  := GIT_CONTENT_SHA 
$(SMARTSWITCH_AZS_PY3)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(SMARTSWITCH_AZS_PY3)_DEP_FILES   := $(DEP_FILES)
$(SMARTSWITCH_AZS_PY3)_SMDEP_FILES := $(SMDEP_FILES)
$(SMARTSWITCH_AZS_PY3)_SMDEP_PATHS := $(SPATH)