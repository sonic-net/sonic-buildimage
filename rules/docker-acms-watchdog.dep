DPATH       := $($(DOCKER_ACMS_WATCHDOG)_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/docker-acms-watchdog.mk rules/docker-acms-watchdog.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(DPATH))

$(DOCKER_ACMS_WATCHDOG)_CACHE_MODE  := GIT_CONTENT_SHA
$(DOCKER_ACMS_WATCHDOG)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(DOCKER_ACMS_WATCHDOG)_DEP_FILES   := $(DEP_FILES)

$(eval $(call add_dbg_docker,$(DOCKER_ACMS_WATCHDOG),$(DOCKER_ACMS_WATCHDOG_DBG)))
