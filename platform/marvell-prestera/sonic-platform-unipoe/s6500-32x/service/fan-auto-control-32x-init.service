[Unit]
Description=Platform 32x monitoring Service
After=pddf-platform-init.service
Before=pmon.target
DefaultDependencies=no

[Service]
ExecStart=/usr/local/bin/pddf_32x_fan_control_sensor_refresh.py
Restart=always
RestartSec=30s
KillSignal=SIGKILL
SuccessExitStatus=SIGKILL

[Install]
WantedBy=multi-user.target
