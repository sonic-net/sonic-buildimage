MPATH       := $($(S6500_32X_PLATFORM)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) $(PLATFORM_PATH)/platform-unipoe.dep $(PLATFORM_PATH)/platform-unipoe.mk
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
SMDEP_FILES := $(addprefix $(MPATH)/,$(shell cd $(MPATH) && git ls-files))

$(S6500_32X_PLATFORM)_CACHE_MODE  := GIT_CONTENT_SHA
$(S6500_32X_PLATFORM)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(S6500_32X_PLATFORM)_DEP_FILES   := $(DEP_FILES)
$(S6500_32X_PLATFORM)_SMDEP_FILES := $(SMDEP_FILES)
