MPATH       := $($(ALLIEDTELESIS_X980_32CQ_PLATFORM)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) $(PLATFORM_PATH)/platform-alliedtelesis.mk $(PLATFORM_PATH)/platform-alliedtelesis.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(MPATH))

$(ALLIEDTELESIS_X980_32CQ_PLATFORM)_CACHE_MODE  := GIT_CONTENT_SHA
$(ALLIEDTELESIS_X980_32CQ_PLATFORM)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(ALLIEDTELESIS_X980_32CQ_PLATFORM)_DEP_FILES   := $(DEP_FILES)
