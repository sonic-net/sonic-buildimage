# Unipoe Platform modules

S6500_PLATFORM_MODULE_VERSION = 1.0


ifeq ($(CONFIGURED_ARCH),arm64)

S6500_32X_PLATFORM = sonic-platform-s6500-32x_$(S6500_PLATFORM_MODULE_VERSION)_$(CONFIGURED_ARCH).deb
$(S6500_32X_PLATFORM)_SRC_PATH = $(PLATFORM_PATH)/sonic-platform-unipoe
$(S6500_32X_PLATFORM)_DEPENDS += $(LINUX_HEADERS) $(LINUX_HEADERS_COMMON)
$(S6500_32X_PLATFORM)_PLATFORM = arm64-unipoe_s6500_32x-r0
SONIC_DPKG_DEBS += $(S6500_32X_PLATFORM)

endif
