
MPATH       := $($(CLS_DS1000_PLATFORM_MODULE_VERSION)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) platform/broadcom/platform-modules-cls.mk platform/broadcom/platform-modules-cls.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
DEP_FILES   += $(shell git ls-files $(MPATH))

$(CLS_DS1000_PLATFORM_MODULE_VERSION)_CACHE_MODE  := GIT_CONTENT_SHA 
$(CLS_DS1000_PLATFORM_MODULE_VERSION)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(CLS_DS1000_PLATFORM_MODULE_VERSION)_DEP_FILES   := $(DEP_FILES)

