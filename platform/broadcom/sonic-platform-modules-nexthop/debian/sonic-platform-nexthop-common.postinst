# Conditionally enable and start mfg-boot-config service only if kernel parameter is present
if grep -q "nexthop_mfg_mode=1" /proc/cmdline 2>/dev/null; then
    /usr/local/bin/mfg-boot-config.sh
fi

if [ "$1" = "configure" ] && [ -f /host/machine.conf ]; then
    . /host/machine.conf
    PLATFORM_SYMLINK="/usr/share/sonic/device/${onie_platform}"

    # Install nexthop_utils wheel on the host. The Nexthop per-card deb ships the
    # wheel to /usr/share/sonic/device/<plat>/ via dh_install; we just need to
    # pip-install it so host scripts (idprom, adm1266_rtc_sync, transceiver_init.py)
    # can `import nexthop_utils`. --no-deps avoids fetching click/natsort from PyPI
    # (both are pre-installed on the host's Python env).
    # PMON-side install is handled separately by dockers/docker-platform-monitor/docker_init.j2.
    NEXTHOP_UTILS_WHL="${PLATFORM_SYMLINK}/nexthop_utils-1.0-py3-none-any.whl"
    if [ -f "${NEXTHOP_UTILS_WHL}" ]; then
        pip3 install --root-user-action=ignore --force-reinstall --no-deps "${NEXTHOP_UTILS_WHL}"
    fi

    # BMC USB network interface (Switch-Host): the BMC's USB NCM gadget enumerates
    # as usb0; 70-usb-network.rules renames it to bmc0 at the udev add event on
    # every boot. On first boot, when usb0 is created is not certain so trigger
    # a synthetic "add" event if the device already exists. 
    PLATFORM_ENV_CONF="${PLATFORM_SYMLINK}/platform_env.conf"
    if [ -f "${PLATFORM_ENV_CONF}" ] && grep -q '^switch_host=1' "${PLATFORM_ENV_CONF}"; then
        udevadm control --reload-rules 2>/dev/null || true
        if udevadm info /sys/class/net/usb0 >/dev/null 2>&1; then
            udevadm trigger --action=add /sys/class/net/usb0 2>&1 >/dev/null || true
            udevadm settle --timeout=10 >/dev/null 2>&1 || true
        fi
    fi
fi
