# Celestica DX010 and Haliburton Platform modules

CLS_DX010_PLATFORM_MODULE_VERSION = 1.0
CLS_HALIBURTON_PLATFORM_MODULE_VERSION = 1.0
CLS_QUESTONE2_PLATFORM_MODULE_VERSION = 1.0
CLS_SEASTONE2_PLATFORM_MODULE_VERSION = 1.0
CLS_SILVERSTONE_PLATFORM_MODULE_VERSION = 1.0
CLS_DS1000_PLATFORM_MODULE_VERSION = 1.0
CLS_DS2000_PLATFORM_MODULE_VERSION = 1.0
CLS_DS3000_PLATFORM_MODULE_VERSION = 1.0
CLS_DS4000_PLATFORM_MODULE_VERSION = 1.0

export CLS_DX010_PLATFORM_MODULE_VERSION
export CLS_HALIBURTON_PLATFORM_MODULE_VERSION
export CLS_QUESTONE2_PLATFORM_MODULE_VERSION
export CLS_SEASTONE2_PLATFORM_MODULE_VERSION
