CLS_DX010_PLATFORM_MODULE = platform-modules-dx010_$(CLS_DX010_PLATFORM_MODULE_VERSION)_amd64.deb
$(CLS_DX010_PLATFORM_MODULE)_SRC_PATH = $(PLATFORM_PATH)/sonic-platform-modules-cls
$(CLS_DX010_PLATFORM_MODULE)_DEPENDS += $(LINUX_HEADERS) $(LINUX_HEADERS_COMMON) $(PDDF_PLATFORM_MODULE_SYM)
$(CLS_DX010_PLATFORM_MODULE)_PLATFORM = x86_64-cel_seastone-r0
SONIC_DPKG_DEBS += $(CLS_DX010_PLATFORM_MODULE)

CLS_HALIBURTON_PLATFORM_MODULE = platform-modules-haliburton_$(CLS_HALIBURTON_PLATFORM_MODULE_VERSION)_amd64.deb
$(CLS_HALIBURTON_PLATFORM_MODULE)_PLATFORM = x86_64-cel_e1031-r0
$(eval $(call add_extra_package,$(CLS_DX010_PLATFORM_MODULE),$(CLS_HALIBURTON_PLATFORM_MODULE)))

CLS_QUESTONE2_PLATFORM_MODULE = platform-modules-questone2_$(CLS_QUESTONE2_PLATFORM_MODULE_VERSION)_amd64.deb
