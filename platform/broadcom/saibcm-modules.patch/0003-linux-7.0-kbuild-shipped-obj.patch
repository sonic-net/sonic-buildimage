Index: saibcm-modules/make/Makefile.linux-kmodule
===================================================================
--- saibcm-modules.orig/make/Makefile.linux-kmodule
+++ saibcm-modules/make/Makefile.linux-kmodule
@@ -142,11 +142,16 @@ else
 $(KMODULE):
 	rm -f *.o *.ko .*.cmd
 	rm -fr .tmp_versions
-	ln -s $(LIBDIR)/$(MODULE) $(PRE_COMPILED_OBJ)_shipped
+	# Linux 7.0 kbuild's _shipped copy rule is $(obj)/%: $(src)/%_shipped
+	# (scripts/Makefile.lib), which does not match the bare constituent name
+	# referenced by composite-module dependencies, so the module link fails
+	# with "No rule to make target obj_$(MOD_NAME).o". Provide the object
+	# directly (no _shipped indirection) so kbuild finds it as a prebuilt file.
+	cp -f $(LIBDIR)/$(MODULE) $(PRE_COMPILED_OBJ)
 	if [ ! -f $(KERNBLDDIR)/NO_SUPRESS ]; then echo "# suppress warning" > .$(PRE_COMPILED_OBJ).cmd; fi
 	$(MAKE) -C $(KERNBLDDIR) CROSS_COMPILE=$(CROSS_COMPILE) M=$(PWD) modules
 	if [ ! -f Module.symvers ]; then echo "old kernel (pre-2.6.17)" > Module.symvers; fi
 	cp -f $(KMODULE) $(LIBDIR)
-	rm -f $(PRE_COMPILED_OBJ)_shipped
+	rm -f $(PRE_COMPILED_OBJ)
 # }
 endif
