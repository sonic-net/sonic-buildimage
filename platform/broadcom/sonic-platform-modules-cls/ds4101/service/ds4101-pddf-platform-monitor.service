[Unit]
Description=DS4101 Platform Monitoring service
Requires=pddf-platform-init.service
After=sonic.target pddf-platform-init.service
BindsTo=pddf-platform-init.service

[Service]
ExecStart=/usr/local/bin/pddf_fan_control_sensor_refresh.py
Restart=always
RestartSec=30s
KillSignal=SIGKILL
SuccessExitStatus=SIGKILL

# Resource Limitations
LimitCORE=infinity

[Install]
WantedBy=multi-user.target
