 bgpd/bgp_mplsvpn.h |  12 +++
 bgpd/bgp_srv6.c    | 201 +++++++++++++++++++++++++++++++++++++++++++++
 bgpd/bgp_srv6.h    |  26 ++++++
 bgpd/bgp_vty.c     | 164 +++++++++++++++++++++++++++++++++++-
 bgpd/bgp_zebra.c   | 109 ++++++++++++++++--------
 bgpd/bgpd.c        |  19 ++++-
 bgpd/bgpd.h        |  17 +++-
 bgpd/subdir.am     |   2 +
 9 files changed, 515 insertions(+), 38 deletions(-)
 create mode 100644 bgpd/bgp_srv6.c
 create mode 100644 bgpd/bgp_srv6.h

