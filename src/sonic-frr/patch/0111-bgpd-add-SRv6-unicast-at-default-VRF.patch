@@ -85,6 +86,8 @@ struct bgp_dest {
 
 	mpls_label_t local_label;
 
+	struct bgp_attr_srv6_l3service *srv6_unicast;
+
 	uint16_t flags;
 #define BGP_NODE_PROCESS_SCHEDULED	(1 << 0)
 #define BGP_NODE_USER_CLEAR             (1 << 1)

From 0e1ec43c58021398d769307583a62f9bb9fed9dc Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Lo=C3=AFc=20Sang?= <loic.sang@6wind.com>
Date: Mon, 25 Aug 2025 10:40:52 +0200
Subject: [PATCH 5/9] bgpd: announce bgp srv6 unicast
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

add new command "neighbor <X:X::X:X|WORD> <encapsulation-srv6|
encapsulation-srv6-relax>":
- At activation, it will re-announce unicast routes that contain srv6
  attribute to the concerned neighbors.
- announce srv6 unicast routes only to neighbors with
"encapsulation-srv6*" enbaled.

