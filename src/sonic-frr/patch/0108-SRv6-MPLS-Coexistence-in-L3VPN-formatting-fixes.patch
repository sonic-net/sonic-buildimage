From 4c3290b9badf934bb1d71dc07cc66e42c59c4bb3 Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Mon, 29 Sep 2025 11:42:06 +0200
Subject: [PATCH 2/4] bgpd: ease srv6 encapsulation code readability

Add a common if brace for MPLS.

Fixes: 8e6bb4a07078 ("bgpd: add neighbor <encapsulation-srv6|encapsulation-mpls> command")

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
---
 bgpd/bgp_route.c | 24 ++++++++++++------------
 1 file changed, 12 insertions(+), 12 deletions(-)

diff --git a/bgpd/bgp_route.c b/bgpd/bgp_route.c
index 5de3e25eeee6..bfa7ab32deb7 100644
--- a/bgpd/bgp_route.c
+++ b/bgpd/bgp_route.c
@@ -2620,19 +2620,19 @@ bool subgroup_announce_check(struct bgp_dest *dest, struct bgp_path_info *pi,
 		}
 	}
 
-	if (safi == SAFI_MPLS_VPN &&
-	    CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_SRV6) &&
-	    !CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_MPLS) &&
-	    !pi->attr->srv6_l3vpn && !pi->attr->srv6_vpn)
-		/* MPLS update not advertised if SRv6 is autorised, but not MPLS */
-		return false;
+	if (safi == SAFI_MPLS_VPN) {
+		if (CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_SRV6) &&
+		    !CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_MPLS) &&
+		    !pi->attr->srv6_l3vpn && !pi->attr->srv6_vpn)
+			/* MPLS update not advertised if SRv6 is autorised, but not MPLS */
+			return false;
 
-	if (safi == SAFI_MPLS_VPN &&
-	    CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_MPLS) &&
-	    !CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_SRV6) &&
-	    (pi->attr->srv6_l3vpn || pi->attr->srv6_vpn))
-		/* SRv6 update not advertised if MPLS is autorised, but not SRv6 */
-		return false;
+		if (CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_MPLS) &&
+		    !CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_SRV6) &&
+		    (pi->attr->srv6_l3vpn || pi->attr->srv6_vpn))
+			/* SRv6 update not advertised if MPLS is autorised, but not SRv6 */
+			return false;
+	}
 
 	bgp_peer_remove_private_as(bgp, afi, safi, peer, attr);
 	bgp_peer_as_override(bgp, afi, safi, peer, attr);

From 767b52e46827e7ba3c7094fd75617b6c27102471 Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Mon, 29 Sep 2025 11:46:49 +0200
Subject: [PATCH 3/4] bgpd: change order of if condition

The test on the safi case is the most important here. Put it in first
order.

Fixes: 6ea7565da1b5 ("bgpd: handle l3vpn bgp updates at reception, be it MPLS or SRv6")

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
---
 bgpd/bgp_route.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/bgpd/bgp_route.c b/bgpd/bgp_route.c
index bfa7ab32deb7..4932f4a6b07c 100644
--- a/bgpd/bgp_route.c
+++ b/bgpd/bgp_route.c
@@ -5058,8 +5058,8 @@ void bgp_update_check_valid_flags(struct bgp *bgp, struct peer *peer, struct bgp
 		    CHECK_FLAG(peer->flags, PEER_FLAG_IS_RFAPI_HD)) {
 			if (accept_own)
 				bgp_path_info_set_flag(dest, pi, BGP_PATH_ACCEPT_OWN);
-			if (pi->peer && pi->peer->bgp->peer_self != pi->peer &&
-			    safi == SAFI_MPLS_VPN) {
+			if (safi == SAFI_MPLS_VPN && pi->peer &&
+			    pi->peer->bgp->peer_self != pi->peer) {
 				if (pi->attr->srv6_l3vpn || pi->attr->srv6_vpn) {
 					if (peergroup_af_flag_check(peer, afi, SAFI_MPLS_VPN,
 								    PEER_FLAG_CONFIG_ENCAPSULATION_SRV6) ||

