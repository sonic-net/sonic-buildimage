 		}
 
 		/* refresh per-vrf tovpn_sid */
@@ -3895,68 +3935,24 @@ static void bgp_zebra_process_srv6_locator_delete_per_bgp(struct srv6_locator *l
 			tmp_prefi.family = AF_INET6;
 			tmp_prefi.prefixlen = IPV6_MAX_BITLEN;
