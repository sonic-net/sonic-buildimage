From e3c2bc32f0654c0173dba753cd78c6da247c0683 Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Wed, 20 Aug 2025 15:45:06 +0200
Subject: [PATCH 1/8] topotests: bgp_srv6l3vpn_sid, check that locator change
 impacts VRF only

When removing the BGP instance from a VRF instance, all SIDs from all
BGP instances are reallocated. To illustrate, before:

> r1# show segment-routing srv6 sid
>  SID               Behavior    Context        Daemon/Instance    Locator    AllocationType
>  ----------------------------  -------------  -----------------  ---------  ----------------
>  2001:db8:1:1:1::  End.DT4     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2001:db8:1:1:2::  End.DT6     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2002:db8:1:1:1::  End.DT6     VRF 'vrf20'    bgp(0)             loc2       dynamic

The expectation is to only reallocate the SID of the BGP which has its
locator updated.

> r1# show segment-routing srv6 sid
>  SID               Behavior    Context        Daemon/Instance    Locator    AllocationType
>  ----------------------------  -------------  -----------------  ---------  ----------------
>  2001:db8:1:1:1::  End.DT6     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2001:db8:1:1:2::  End.DT6     VRF 'vrf20'    bgp(0)             loc1       dynamic
>  2001:db8:1:1:3::  End.DT4     VRF 'vrf10'    bgp(0)             loc1       dynamic

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
---
 .../topotests/bgp_srv6l3vpn_sid/r2/vrf20_rib_one_locator.json | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/tests/topotests/bgp_srv6l3vpn_sid/r2/vrf20_rib_one_locator.json b/tests/topotests/bgp_srv6l3vpn_sid/r2/vrf20_rib_one_locator.json
index acf65e8fe01d..8bc2fc23f147 100644
--- a/tests/topotests/bgp_srv6l3vpn_sid/r2/vrf20_rib_one_locator.json
+++ b/tests/topotests/bgp_srv6l3vpn_sid/r2/vrf20_rib_one_locator.json
@@ -39,14 +39,14 @@
           "vrf":"default",
           "active":true,
           "labels":[
-            32
+            48
           ],
           "weight":1,
           "seg6local":{
             "action":"unspec"
           },
           "seg6":{
-            "segs":"2001:db8:1:1:2::"
+            "segs":"2001:db8:1:1:3::"
           }
         }
       ]

From 8d6c366ca69db39c9acdb2addc0cc069db9ca7f6 Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Mon, 8 Sep 2025 09:25:48 +0200
Subject: [PATCH 2/8] bgpd: add comment to inform default l3vpn sid entries are
 ignored

The current code has some limitations when supporting SID entries in the
default VRF instance. Add a comment to explain the reason.

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
---
 bgpd/bgp_vty.c   | 2 ++
 bgpd/bgp_zebra.c | 2 ++
 2 files changed, 4 insertions(+)

diff --git a/bgpd/bgp_vty.c b/bgpd/bgp_vty.c
index e11f228b6bda..5820bd20bac8 100644
--- a/bgpd/bgp_vty.c
+++ b/bgpd/bgp_vty.c
@@ -315,6 +315,7 @@ static int bgp_srv6_locator_unset(struct bgp *bgp)
 	/* refresh tovpn_sid */
 	for (ALL_LIST_ELEMENTS_RO(bm->bgp, node, bgp_vrf)) {
 		if (bgp_vrf->inst_type != BGP_INSTANCE_TYPE_VRF)
+			/* TODO: accept SRv6 entries on default VRF */
 			continue;
 
 		/* refresh vpnv4 tovpn_sid */
@@ -335,6 +336,7 @@ static int bgp_srv6_locator_unset(struct bgp *bgp)
 	/* refresh tovpn_sid_locator */
 	for (ALL_LIST_ELEMENTS_RO(bm->bgp, node, bgp_vrf)) {
 		if (bgp_vrf->inst_type != BGP_INSTANCE_TYPE_VRF)
+			/* TODO: accept SRv6 entries on default VRF */
 			continue;
 
 		/* refresh vpnv4 tovpn_sid_locator */
diff --git a/bgpd/bgp_zebra.c b/bgpd/bgp_zebra.c
index bdf2e3a4edc8..937775509c47 100644
--- a/bgpd/bgp_zebra.c
+++ b/bgpd/bgp_zebra.c
@@ -3862,6 +3862,7 @@ static void bgp_zebra_process_srv6_locator_delete_per_bgp(struct srv6_locator *l
 			continue;
 
 		if (bgp_vrf->inst_type != BGP_INSTANCE_TYPE_VRF)
+			/* TODO: accept SRv6 entries on default VRF */
 			continue;
 
 		// refresh vpnv4 tovpn_sid
@@ -3908,6 +3909,7 @@ static void bgp_zebra_process_srv6_locator_delete_per_bgp(struct srv6_locator *l
 			continue;
 
 		if (bgp_vrf->inst_type != BGP_INSTANCE_TYPE_VRF)
+			/* TODO: accept SRv6 entries on default VRF */
 			continue;
 
 		/* refresh vpnv4 tovpn_sid_locator */

From 6b33ff7f1d574f68c29e87a77d5b8fbdf2aead37 Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Thu, 28 Aug 2025 08:55:01 +0200
Subject: [PATCH 3/8] bgpd: fix sids not removed when changing locator

When removing a locator, the SID is not released from the srv6 SID
manager:

> r1(config-router-srv6)# do show segment-routing srv6 sid
>  SID               Behavior    Context        Daemon/Instance    Locator    AllocationType
>  ----------------------------  -------------  -----------------  ---------  ----------------
>  2001:db8:1:1:1::  End.DT4     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2001:db8:1:1:2::  End.DT6     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2002:db8:2:1:3::  End.DT6     VRF 'vrf20'    bgp(0)             loc1       dynamic
>
> r1(config-router-srv6)# no locator loc2
> r1(config-router-srv6)# do show segment-routing srv6 sid
>  SID               Behavior    Context        Daemon/Instance    Locator    AllocationType
>  ----------------------------  -------------  -----------------  ---------  ----------------
>  2001:db8:1:1:1::  End.DT4     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2001:db8:1:1:2::  End.DT6     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2002:db8:2:1:3::  End.DT6     VRF 'vrf20'    bgp(0)             loc1       dynamic

Also, when adding a locator on a VRF instance, the old SID is not
release from the srv6 SID manager.

> r1(config-router-srv6)# locator loc2
> r1(config-router-srv6)# do show segment-routing srv6 sid
>  SID               Behavior    Context        Daemon/Instance    Locator    AllocationType
>  ----------------------------  -------------  -----------------  ---------  ----------------
>  2001:db8:1:1:1::  End.DT4     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2001:db8:1:1:2::  End.DT6     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2002:db8:1:1:3::  End.DT6     VRF 'vrf20'    bgp(0)             loc1       dynamic
>
> r1(config-router-srv6)# locator loc2
> r1(config-router-srv6)# do show segment-routing srv6 sid
>  SID               Behavior    Context        Daemon/Instance    Locator    AllocationType
>  ----------------------------  -------------  -----------------  ---------  ----------------
>  2001:db8:1:1:1::  End.DT4     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2001:db8:1:1:2::  End.DT6     VRF 'vrf10'    bgp(0)             loc1       dynamic
>  2001:db8:1:1:3::  End.DT6     VRF 'vrf20'    bgp(0)             loc1       dynamic

The dereferencement of a locator has not been modified for the
introduction of the locator per bgp instance configuration. Change the
algorithm by creating a separate function, bgp_srv6_sids_unset().The
passed BGP instance will be refreshed to release SIDs, locator and
routes. Afer this call, the vpn_leak_postchange_all() function will
look for new SIDs/locator routes if necessary.

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
---
 bgpd/bgp_vty.c | 83 ++++++++++++++++++++++++++++++++++++++------------
 1 file changed, 64 insertions(+), 19 deletions(-)

diff --git a/bgpd/bgp_vty.c b/bgpd/bgp_vty.c
index 5820bd20bac8..ff2757c69f17 100644
--- a/bgpd/bgp_vty.c
+++ b/bgpd/bgp_vty.c
@@ -292,13 +292,34 @@ static const char *get_afi_safi_json_str(afi_t afi, safi_t safi)
 	return "Unknown";
 }
 
-/* unset srv6 locator */
-static int bgp_srv6_locator_unset(struct bgp *bgp)
+static void bgp_srv6_sids_unset(struct bgp *bgp)
 {
 	struct listnode *node, *nnode;
 	struct srv6_locator_chunk *chunk;
 	struct bgp_srv6_function *func;
 	struct bgp *bgp_vrf;
+	struct srv6_sid_ctx ctx = {};
+
+	for (ALL_LIST_ELEMENTS_RO(bm->bgp, node, bgp_vrf)) {
+		if (bgp_vrf->inst_type != BGP_INSTANCE_TYPE_VRF)
+			/* TODO: accept SRv6 entries on default VRF */
+			continue;
+
+		if (bgp->inst_type == BGP_INSTANCE_TYPE_VRF && bgp_vrf != bgp)
+			continue;
+
+		if (bgp->inst_type == BGP_INSTANCE_TYPE_DEFAULT && bgp != bgp_vrf &&
+		    bgp_vrf->srv6_locator)
+			/* bgp_vrf has an active locator, we have to keep it */
+			continue;
+
+		if (bgp_vrf->vpn_policy[AFI_IP].tovpn_sid)
+			vpn_leak_prechange(BGP_VPN_POLICY_DIR_TOVPN, AFI_IP, bgp_get_default(),
+					   bgp_vrf);
+		if (bgp_vrf->vpn_policy[AFI_IP6].tovpn_sid)
+			vpn_leak_prechange(BGP_VPN_POLICY_DIR_TOVPN, AFI_IP6, bgp_get_default(),
+					   bgp_vrf);
+	}
 
 	/* refresh chunks */
 	for (ALL_LIST_ELEMENTS(bgp->srv6_locator_chunks, node, nnode, chunk)) {
@@ -318,26 +339,41 @@ static int bgp_srv6_locator_unset(struct bgp *bgp)
 			/* TODO: accept SRv6 entries on default VRF */
 			continue;
 
-		/* refresh vpnv4 tovpn_sid */
-		XFREE(MTYPE_BGP_SRV6_SID,
-		      bgp_vrf->vpn_policy[AFI_IP].tovpn_sid);
+		if (bgp->inst_type == BGP_INSTANCE_TYPE_VRF && bgp_vrf != bgp)
+			continue;
 
-		/* refresh vpnv6 tovpn_sid */
-		XFREE(MTYPE_BGP_SRV6_SID,
-		      bgp_vrf->vpn_policy[AFI_IP6].tovpn_sid);
+		if (bgp->inst_type == BGP_INSTANCE_TYPE_DEFAULT && bgp != bgp_vrf &&
+		    bgp_vrf->srv6_locator)
+			/* bgp_vrf has an active locator, we have to keep it */
+			continue;
 
-		/* refresh per-vrf tovpn_sid */
-		XFREE(MTYPE_BGP_SRV6_SID, bgp_vrf->tovpn_sid);
-	}
+		ctx.vrf_id = bgp_vrf->vrf_id;
 
-	/* update vpn bgp processes */
-	vpn_leak_postchange_all();
+		if (bgp_vrf->vpn_policy[AFI_IP].tovpn_sid) {
+			/* release vpnv4 tovpn_sid */
+			ctx.behavior = ZEBRA_SEG6_LOCAL_ACTION_END_DT4;
+			bgp_zebra_release_srv6_sid(&ctx, bgp_vrf->vpn_policy[AFI_IP]
+								 .tovpn_sid_locator->name);
+			/* refresh vpnv4 tovpn_sid */
+			XFREE(MTYPE_BGP_SRV6_SID, bgp_vrf->vpn_policy[AFI_IP].tovpn_sid);
+		}
 
-	/* refresh tovpn_sid_locator */
-	for (ALL_LIST_ELEMENTS_RO(bm->bgp, node, bgp_vrf)) {
-		if (bgp_vrf->inst_type != BGP_INSTANCE_TYPE_VRF)
-			/* TODO: accept SRv6 entries on default VRF */
-			continue;
+		if (bgp_vrf->vpn_policy[AFI_IP6].tovpn_sid) {
+			/* release vpnv6 tovpn_sid */
+			ctx.behavior = ZEBRA_SEG6_LOCAL_ACTION_END_DT6;
+			bgp_zebra_release_srv6_sid(&ctx, bgp_vrf->vpn_policy[AFI_IP6]
+								 .tovpn_sid_locator->name);
+			/* refresh vpnv6 tovpn_sid */
+			XFREE(MTYPE_BGP_SRV6_SID, bgp_vrf->vpn_policy[AFI_IP6].tovpn_sid);
+		}
+
+		if (bgp_vrf->tovpn_sid) {
+			/* release vpnvx tovpn_sid */
+			ctx.behavior = ZEBRA_SEG6_LOCAL_ACTION_END_DT46;
+			bgp_zebra_release_srv6_sid(&ctx, bgp_vrf->tovpn_sid_locator->name);
+			/* refresh per-vrf tovpn_sid */
+			XFREE(MTYPE_BGP_SRV6_SID, bgp_vrf->tovpn_sid);
+		}
 
 		/* refresh vpnv4 tovpn_sid_locator */
 		srv6_locator_free(bgp_vrf->vpn_policy[AFI_IP].tovpn_sid_locator);
@@ -352,6 +388,13 @@ static int bgp_srv6_locator_unset(struct bgp *bgp)
 		srv6_locator_free(bgp_vrf->tovpn_sid_locator);
 		bgp_vrf->tovpn_sid_locator = NULL;
 	}
+}
+
+/* unset srv6 locator */
+static int bgp_srv6_locator_unset(struct bgp *bgp)
+{
+	/* clear function, sids */
+	bgp_srv6_sids_unset(bgp);
 
 	/* clear locator name */
 	memset(bgp->srv6_locator_name, 0, sizeof(bgp->srv6_locator_name));
@@ -361,7 +404,7 @@ static int bgp_srv6_locator_unset(struct bgp *bgp)
 		srv6_locator_free(bgp->srv6_locator);
 		bgp->srv6_locator = NULL;
 	}
-
+	vpn_leak_postchange_all();
 	return 0;
 }
 
@@ -11158,6 +11201,8 @@ DEFPY (bgp_srv6_locator,
 		return CMD_WARNING_CONFIG_FAILED;
 	}
 
+	bgp_srv6_sids_unset(bgp);
+
 	snprintf(bgp->srv6_locator_name,
 		 sizeof(bgp->srv6_locator_name), "%s", name);
 

From 948a25b4e886c2e57ce5eda0e44867c55240555a Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Mon, 1 Sep 2025 10:54:52 +0200
Subject: [PATCH 4/8] bgpd: fix sids not removed when locator info is deleted

When locator is removed from the srv6 zebra configuration, BGP VPN
entries are unselected, but still keep the old SID information.
Fix this by flushing the related VPN entries.
Also simplify the code by using a single loop to modify both locators
and sids.
Call the vpn_leak_postchange_all() function in the end.

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
