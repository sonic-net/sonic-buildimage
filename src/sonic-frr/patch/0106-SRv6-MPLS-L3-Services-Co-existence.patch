From 8e6bb4a070785dad72ce6667917df68e85013075 Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Tue, 8 Jul 2025 18:05:46 +0200
Subject: [PATCH 08/14] bgpd: add neighbor
 <encapsulation-srv6|encapsulation-mpls> command

RFC9252 mentions:
"Implementations supporting this specification MUST provide a mechanism
to control the advertisement of SRv6-based BGP service routes on a
per-neighbor basis".

There is no control on how to filter out BGP VPN updates per peer, and
some peers may be unable to handle incoming BGP SRv6 updates, and may
see the BGP update as MPLS packet.

Fix this by proposing a config command under the ipv4-vpn and the
ipv6-vpn addres families:

> dut# neighbor A:B::C:D <encapsulation-srv6|encapsulation-mpls>

Without those commands, there is no filtering and if both MPLS and SRv6
paths are exported: without add-path, only the MPLS VPN path will be
advertised; with add-path, both the MPLS VPN path and the SRv6 VPN path
will be advertised.

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
---
 bgpd/bgp_route.c             | 14 ++++++++++
 bgpd/bgp_updgrp.h            | 21 ++++++++-------
 bgpd/bgp_vty.c               | 50 ++++++++++++++++++++++++++++++++++++
 bgpd/bgpd.c                  |  2 ++
 bgpd/bgpd.h                  |  2 ++
 doc/user/bgp.rst             | 11 ++++++++
 tests/bgpd/test_peer_attr.c  | 12 +++++++++
 tests/bgpd/test_peer_attr.py |  4 +++
 8 files changed, 105 insertions(+), 11 deletions(-)

diff --git a/bgpd/bgp_route.c b/bgpd/bgp_route.c
index 6f93eac6c4ff..2fc58ea64955 100644
--- a/bgpd/bgp_route.c
+++ b/bgpd/bgp_route.c
@@ -2620,6 +2620,20 @@ bool subgroup_announce_check(struct bgp_dest *dest, struct bgp_path_info *pi,
 		}
 	}
 
+	if (safi == SAFI_MPLS_VPN &&
+	    CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_SRV6) &&
+	    !CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_MPLS) &&
+	    !pi->attr->srv6_l3vpn && !pi->attr->srv6_vpn)
+		/* MPLS update not advertised if SRv6 is autorised, but not MPLS */
+		return false;
+
+	if (safi == SAFI_MPLS_VPN &&
+	    CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_MPLS) &&
+	    !CHECK_FLAG(peer->af_flags[afi][safi], PEER_FLAG_CONFIG_ENCAPSULATION_SRV6) &&
+	    (pi->attr->srv6_l3vpn || pi->attr->srv6_vpn))
+		/* SRv6 update not advertised if MPLS is autorised, but not SRv6 */
+		return false;
+
 	bgp_peer_remove_private_as(bgp, afi, safi, peer, attr);
 	bgp_peer_as_override(bgp, afi, safi, peer, attr);
 
diff --git a/bgpd/bgp_updgrp.h b/bgpd/bgp_updgrp.h
