From 42bf0ab301d69064682e5331e77029e628abd56d Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Wed, 10 Sep 2025 13:35:29 +0200
Subject: [PATCH 12/14] bgpd: fix entry not removed when locator changed on
 per-vrf config

When a BGP VRF instance has a per-vrf sid configured, the removal of a
locator does not trigger the removal of the exported VPN entry. Fix this
by adding the missing call.

Fixes: 6b33ff7f1d57 ("bgpd: fix sids not removed when changing locator")

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
---
 bgpd/bgp_vty.c | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/bgpd/bgp_vty.c b/bgpd/bgp_vty.c
index 9c2310276476..abecec84be33 100644
--- a/bgpd/bgp_vty.c
+++ b/bgpd/bgp_vty.c
@@ -313,10 +313,10 @@ static void bgp_srv6_sids_unset(struct bgp *bgp)
 			/* bgp_vrf has an active locator, we have to keep it */
 			continue;
 
-		if (bgp_vrf->vpn_policy[AFI_IP].tovpn_sid)
+		if (bgp_vrf->vpn_policy[AFI_IP].tovpn_sid || bgp_vrf->tovpn_sid)
 			vpn_leak_prechange(BGP_VPN_POLICY_DIR_TOVPN, AFI_IP, bgp_get_default(),
 					   bgp_vrf);
-		if (bgp_vrf->vpn_policy[AFI_IP6].tovpn_sid)
+		if (bgp_vrf->vpn_policy[AFI_IP6].tovpn_sid || bgp_vrf->tovpn_sid)
 			vpn_leak_prechange(BGP_VPN_POLICY_DIR_TOVPN, AFI_IP6, bgp_get_default(),
 					   bgp_vrf);
 	}

