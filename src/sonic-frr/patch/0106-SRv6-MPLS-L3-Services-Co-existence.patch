@@ -39,17 +39,16 @@
 #define PEER_UPDGRP_FLAGS                                                      \
 	(PEER_FLAG_LOCAL_AS_NO_PREPEND | PEER_FLAG_LOCAL_AS_REPLACE_AS)
 
-#define PEER_UPDGRP_AF_FLAGS                                                   \
