+					srv6_locator_free(
+						bgp_vrf->srv6_unicast[AFI_IP6].sid_locator);
+					bgp_vrf->srv6_unicast[AFI_IP6].sid_locator = NULL;
+					XFREE(MTYPE_BGP_SRV6_SID,
+					      bgp_vrf->srv6_unicast[AFI_IP6].sid);
+				}
+
+				/* Unregister the SID */
+				sid_unregister(bgp_vrf, &sid_addr);
+			}
 		} else {
