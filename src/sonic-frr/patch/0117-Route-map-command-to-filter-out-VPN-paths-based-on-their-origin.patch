From e198213c312b75425ae62fdac543a34622548596 Mon Sep 17 00:00:00 2001
From: Philippe Guibert <philippe.guibert@6wind.com>
Date: Mon, 13 Oct 2025 11:33:44 +0200
Subject: [PATCH 1/4] bgpd: add SRv6 encapsulation type define

SRv6 uses different attributes in BGP to tell if SRv6 is to be used or
not. But internally, using the encapsulation type enumerate cases for both
L2VPN (which use encapsulation type), and L3VPN (which do not use
encapsulation type as of today implem of FRR) makes sense.

Signed-off-by: Philippe Guibert <philippe.guibert@6wind.com>
---
 bgpd/bgp_encap_types.h       | 3 ++-
 bgpd/rfapi/rfapi_encap_tlv.c | 2 ++
 2 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/bgpd/bgp_encap_types.h b/bgpd/bgp_encap_types.h
index ea5b54c9e84c..8275e07c87cf 100644
--- a/bgpd/bgp_encap_types.h
+++ b/bgpd/bgp_encap_types.h
@@ -26,7 +26,8 @@ typedef enum {
 	BGP_ENCAP_TYPE_MPLS_IN_GRE = 11,
 	BGP_ENCAP_TYPE_VXLAN_GPE = 12,
 	BGP_ENCAP_TYPE_MPLS_IN_UDP = 13,
-	BGP_ENCAP_TYPE_PBB
+	BGP_ENCAP_TYPE_PBB,
+	BGP_ENCAP_TYPE_SRV6 = 255, /* For internal usage only */
 } bgp_encap_types;
 
 typedef enum {
diff --git a/bgpd/rfapi/rfapi_encap_tlv.c b/bgpd/rfapi/rfapi_encap_tlv.c
index 37a7326151a5..8fdd24f532fd 100644
--- a/bgpd/rfapi/rfapi_encap_tlv.c
+++ b/bgpd/rfapi/rfapi_encap_tlv.c
@@ -137,6 +137,7 @@ rfapi_tunneltype_option_to_tlv(struct bgp *bgp, struct rfapi_ip_addr *ea,
 		bgp_encap_type_pbb_to_tlv(&tto->bgpinfo.pbb, attr);
 		break;
 
+	case BGP_ENCAP_TYPE_SRV6:
 	case BGP_ENCAP_TYPE_RESERVED:
 		assert(!"Cannot process BGP_ENCAP_TYPE_RESERVED");
 	}
@@ -725,6 +726,7 @@ void rfapi_print_tunneltype_option(void *stream, int column_offset,
 		break;
 
 	case BGP_ENCAP_TYPE_RESERVED:
+	case BGP_ENCAP_TYPE_SRV6:
 		assert(!"Cannot process BGP_ENCAP_TYPE_RESERVED");
 	}
 }

