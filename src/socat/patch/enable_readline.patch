Description: Enable readline support in socat.
 Drop the debian/rules override that passes --disable-readline to
 dh_auto_configure so socat's configure auto-detects and links libreadline,
 and add libreadline-dev to Build-Depends.
 .
 Rebased for socat 1.8.1.1-1 (Ubuntu 26.04 "resolute"); the original was
 written against the socat 1.7.x era debian/rules and debian/control layout
 (debhelper-compat 12, no procps, different override_dh_auto_test body) and no
 longer matched the 1.8.1.1-1 packaging.
Author: Sheldon Qi <sheldon.qi@canonical.com>
Forwarded: not-needed
--- a/debian/rules
+++ b/debian/rules
@@ -11,9 +11,6 @@
 # upsteram maintains config.h.in manually
 export AUTOHEADER = true

-override_dh_auto_configure:
-	dh_auto_configure -- --disable-readline
-
 override_dh_auto_test:
 ifneq (,$(filter $(DEB_HOST_ARCH_OS), linux))
 	dh_auto_test
@@ -24,4 +21,4 @@
 %:
 	dh $@ --with=autoreconf

-.PHONY: override_dh_auto_configure override_dh_auto_test
+.PHONY: override_dh_auto_test
--- a/debian/control
+++ b/debian/control
@@ -2,7 +2,7 @@
 Section: net
 Priority: optional
 Maintainer: Laszlo Boszormenyi (GCS) <gcs@debian.org>
-Build-Depends: debhelper-compat (= 13), libssl-dev, libwrap0-dev, openssl <!nocheck>, net-tools <!nocheck>, iproute2 [linux-any] <!nocheck>, netbase <!nocheck>, procps <!nocheck>
+Build-Depends: debhelper-compat (= 13), libssl-dev, libwrap0-dev, libreadline-dev, openssl <!nocheck>, net-tools <!nocheck>, iproute2 [linux-any] <!nocheck>, netbase <!nocheck>, procps <!nocheck>
 Standards-Version: 4.7.2
 Homepage: http://www.dest-unreach.org/socat/

