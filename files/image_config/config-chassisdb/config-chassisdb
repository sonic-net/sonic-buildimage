#!/bin/bash
###########################################################################
# SONiC chassis_db configuration                                          #
#                                                                         #
# This script is used to add chassis_db address in local hosts and        #
# indicate to start database-chassis service. It should be excuted before #
# database-chassis.service started.                                       #
#                                                                         #
###########################################################################

config_chassis_db() {
    startdb_file="/etc/sonic/chassisdb.conf"
    chassisdb_address_file="/etc/sonic/chassisdb_address"
    [ ! -e $startdb_file ] || rm $startdb_file
    platform=${PLATFORM:-`sonic-cfggen -H -v DEVICE_METADATA.localhost.platform`}
    # database-chassis services will start when $chassis_config file exists
    chassis_config="/usr/share/sonic/device/$platform/chassisdb.conf"
    if [ ! -e $chassis_config ]; then
       echo "no chassisdb.conf found, bypass config-chassisdb service"
       exit 0
    fi

    # On virtual switch, retain the original flow, as it don't support most platform APIs
    asic_type=$(python3 -c 'from sonic_py_common.device_info import get_sonic_version_info; \
	                    print(get_sonic_version_info().get("asic_type") or "")')

    if [[ "$asic_type" != "vs" ]]; then
    # Read the various device attributes
    read -r is_supervisor is_disagg is_smartswitch is_dpu < <(python3 -c \
	    'import sonic_py_common.device_info as d; print(*[getattr(d,n,lambda:False)() \
	    for n in ("is_supervisor","is_disaggregated_chassis","is_smartswitch","is_dpu")])')

    # Identify the midplane IP in each sonic platform
    if [[ "$is_disagg" == True ]]; then
        # With disagg T2 pizza box it is docker0 bridge which is midplane
        midplane_interface_ip=$(ip -4 -o addr show "docker0" | \
                              awk '{print $4}' | cut -d/ -f1 | head -n1)
    elif [[ "$is_smartswitch" == True ]] || [[ "$is_dpu" == True ]]; then
        # On smartswitch (NPU or DPU side) get the NPU bridge-midplane IP from the network config file
        midplane_interface_ip=$(python3 -c \
            'import sonic_py_common.device_info as d; print(d.get_smartswitch_midplane_ip() or "")')
    elif [[ "$is_supervisor" == True ]]; then
        # Modular chassis supervisor: midplane IP is on eth1-midplane
        midplane_interface_ip=$(ip -4 -o addr show "eth1-midplane" | \
                              awk '{print $4}' | cut -d/ -f1 | head -n1)
    else
        # Modular chassis linecard: query supervisor's midplane IP via platform API (guarded).
        midplane_interface_ip=$(python3 -c "import sys
try:
    import sonic_platform.platform as p
    c = p.Platform().get_chassis()
    s = c.get_supervisor_slot()
    m = [x.get_midplane_ip() for x in (c.get_all_modules() or [])
         if x.get_slot() == s]
    print(m[0] if m else '')
except Exception as e:
    print('')")
    fi

    # Generate the chassisdb_address_file from the midplane interface ip address
    if [[ -n "$midplane_interface_ip" ]]; then
        echo "chassis_db_address=$midplane_interface_ip" > "$chassisdb_address_file"
    else
        echo "Error: No IP address configured on midplane_interface"
        exit 1
    fi
    fi

    start_chassis_db=0
    chassis_db_address=""

    # source the platform/sku level chassisdb.conf, if the file exists
    source $chassis_config
    # source the new chassisdb_address_file, if the file exists
    [ -f $chassisdb_address_file ] && source $chassisdb_address_file

    # Introduce additional checks so that the chassis_db_address is valid
    # Check if the IP address is not 0.0.0.0
    if [[ "$chassis_db_address" == "0.0.0.0" ]]; then
        echo "Error: chassis_db address configured as 0.0.0.0"
        [ ! -e $chassisdb_address_file ] || rm $chassisdb_address_file
        exit 1
    fi
    # if the midplane subnet is defined make sure the IP address is part of the midplane subnet
    if [[ -n "$midplane_subnet" ]]; then
        result=$(python3 -c "import ipaddress; print(ipaddress.ip_address('$chassis_db_address') \
              in ipaddress.ip_network('$midplane_subnet'))")
        # Exit as error if chassis_db_address not in the midplane subnet or if validation fails
        if [[ $? -ne 0 ]] || [[ "$result" == "False" ]]; then
            echo "Error: chassis_db address does not belong to midplane subnet"
            [ ! -e $chassisdb_address_file ] || rm $chassisdb_address_file
            exit 1
        fi
    fi

    if [[ "$start_chassis_db" == "1" ]]; then
       cp $chassis_config $startdb_file
       echo "start chassisdb"
    fi
    if [[ "$start_chassis_db" == "1" ]] || [[ -n "$chassis_db_address" ]]; then
        if [ -z "$chassis_db_address" ]; then
            echo "no user configured chassisdb address"
        else
            grep redis_chassis /etc/hosts
            if [ $? -ne 0 ]; then
                echo "$chassis_db_address redis_chassis.server" >> /etc/hosts
                echo "update chassis db address to $chassis_db_address"
            fi
        fi
    fi
}

# read SONiC immutable variables
[ -f /etc/sonic/sonic-environment ] && . /etc/sonic/sonic-environment

config_chassis_db

exit 0
